# Copy this file to .env and fill in real values for local development.

# Flask
SECRET_KEY=change-this-to-a-long-random-string
JWT_SECRET_KEY=change-this-to-a-different-long-random-string

# Database
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///instance/inkwell.db
# PostgreSQL (production example):
# DATABASE_URL=postgresql://user:password@localhost:5432/inkwell

# CORS — set to your frontend's URL in production, e.g. https://inkwell.vercel.app
CORS_ORIGINS=*
